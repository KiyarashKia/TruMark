# TruMark frontend environment.
# Copy to .env.local and adjust. All vars are optional — sensible defaults apply.

# Base URL of the blockchain_service (read endpoint for on-chain verification).
VITE_CHAIN_API_URL=http://localhost:3001

# When "false", the app calls the real chain service. Anything else (or unset)
# keeps on-chain verification in deterministic simulation mode — safe for demos.
VITE_SIMULATE_CHAIN=true

# Base URL of the TruMark Recall API (recall_service). When set, recalls are
# checked live against Health Canada / CFIA by UPC. When unset, the app uses a
# small mock recall registry (demo UPCs only).
VITE_RECALL_API_URL=http://localhost:3002
